{
  "schema_id": "ralph-codex/turn-log-line",
  "schema_version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "session_id", "ts", "phase", "turn_id", "status", "summary"],
  "properties": {
    "schema_id": { "type": "string", "enum": ["ralph-codex/turn-log-line"] },
    "schema_version": { "type": "string", "enum": ["0.1.0"] },
    "session_id": { "type": "string", "pattern": "^\\d{8}T\\d{9}Z_[0-9a-f]{12}$" },
    "ts": { "type": "string", "minLength": 1 },
    "phase": { "type": "string", "minLength": 1 },
    "turn_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" }
  }
}
