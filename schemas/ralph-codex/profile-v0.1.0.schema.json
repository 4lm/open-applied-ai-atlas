{
  "schema_id": "ralph-codex/profile",
  "schema_version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "profile_name",
    "model",
    "thread_policy",
    "runtime_limits",
    "seed_policy",
    "prompt_answering",
    "charter_policy",
    "completion_policy",
    "research_policy",
    "tranche_policy",
    "quality_policy",
    "milestone_policy",
    "worker_policy",
    "evidence_policy",
    "eval_policy",
    "planning",
    "evaluation",
    "loop_policy",
    "execution"
  ],
  "properties": {
    "schema_id": { "type": "string", "enum": ["ralph-codex/profile"] },
    "schema_version": { "type": "string", "enum": ["0.1.0"] },
    "profile_name": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "thread_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["access_mode"],
      "properties": {
        "access_mode": { "type": "string", "enum": ["restricted", "dangerously-unrestricted"] }
      }
    },
    "runtime_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_iterations"],
      "properties": {
        "max_iterations": { "type": "integer", "minimum": 0 }
      }
    },
    "seed_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["require_confirmation", "auto_confirm"],
      "properties": {
        "require_confirmation": { "type": "boolean" },
        "auto_confirm": { "type": "boolean" }
      }
    },
    "prompt_answering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reject_secret_questions", "require_selectable_options"],
      "properties": {
        "reject_secret_questions": { "type": "boolean" },
        "require_selectable_options": { "type": "boolean" }
      }
    },
    "charter_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_adjacent_surfaces",
        "require_validation_for_each_workstream",
        "require_validation_categories"
      ],
      "properties": {
        "require_adjacent_surfaces": { "type": "boolean" },
        "require_validation_for_each_workstream": { "type": "boolean" },
        "require_validation_categories": { "type": "boolean" }
      }
    },
    "completion_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_deferred_workstreams",
        "require_all_workstreams_resolved",
        "require_no_remaining_gaps",
        "require_validation_categories_complete"
      ],
      "properties": {
        "allow_deferred_workstreams": { "type": "boolean" },
        "require_all_workstreams_resolved": { "type": "boolean" },
        "require_no_remaining_gaps": { "type": "boolean" },
        "require_validation_categories_complete": { "type": "boolean" }
      }
    },
    "research_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "require_primary_sources_when_available",
        "require_multi_step_search",
        "block_on_search_unavailable"
      ],
      "properties": {
        "mode": { "type": "string", "enum": ["required"] },
        "require_primary_sources_when_available": { "type": "boolean" },
        "require_multi_step_search": { "type": "boolean" },
        "block_on_search_unavailable": { "type": "boolean" }
      }
    },
    "tranche_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["require_explicit_target_files"],
      "properties": {
        "require_explicit_target_files": { "type": "boolean" }
      }
    },
    "quality_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stagnation_escalation_after_iterations",
        "progress_checkpoint_mode"
      ],
      "properties": {
        "stagnation_escalation_after_iterations": { "type": "integer", "minimum": 1 },
        "progress_checkpoint_mode": {
          "type": "string",
          "enum": ["require_confirmation", "record_only_after_seed"]
        }
      }
    },
    "milestone_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkpoint_on_milestone_close", "require_acceptance_bundle"],
      "properties": {
        "checkpoint_on_milestone_close": { "type": "boolean" },
        "require_acceptance_bundle": { "type": "boolean" }
      }
    },
    "worker_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "allowed_roles"],
      "properties": {
        "enabled": { "type": "boolean" },
        "allowed_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["research", "read_only_repo", "evaluator_vote"]
          }
        }
      }
    },
    "evidence_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_relevance_assessment",
        "require_quality_assessment",
        "require_freshness_assessment",
        "refresh_on_replan"
      ],
      "properties": {
        "require_relevance_assessment": { "type": "boolean" },
        "require_quality_assessment": { "type": "boolean" },
        "require_freshness_assessment": { "type": "boolean" },
        "refresh_on_replan": { "type": "boolean" }
      }
    },
    "eval_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptance_confidence_floor"],
      "properties": {
        "acceptance_confidence_floor": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    },
    "planning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "mode", "reasoning_effort", "output_schema_id"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["plan"] },
        "reasoning_effort": { "type": "string", "enum": ["low", "medium", "high", "xhigh"] },
        "output_schema_id": { "type": "string", "enum": ["ralph-codex/output/planning"] }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "mode", "reasoning_effort", "output_schema_id"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["default"] },
        "reasoning_effort": { "type": "string", "enum": ["low", "medium", "high", "xhigh"] },
        "output_schema_id": { "type": "string", "enum": ["ralph-codex/output/evaluation"] }
      }
    },
    "loop_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "same_tranche_escalation_after",
        "replan_escalation_after",
        "require_iteration_repo_baseline",
        "planning_repair_escalation_after",
        "execution_repair_escalation_after",
        "evaluation_repair_escalation_after"
      ],
      "properties": {
        "same_tranche_escalation_after": { "type": "integer", "minimum": 1 },
        "replan_escalation_after": { "type": "integer", "minimum": 1 },
        "require_iteration_repo_baseline": { "type": "boolean" },
        "planning_repair_escalation_after": { "type": "integer", "minimum": 1 },
        "execution_repair_escalation_after": { "type": "integer", "minimum": 1 },
        "evaluation_repair_escalation_after": { "type": "integer", "minimum": 1 }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "mode", "reasoning_effort", "output_schema_id"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["default"] },
        "reasoning_effort": { "type": "string", "enum": ["low", "medium", "high", "xhigh"] },
        "output_schema_id": { "type": "string", "enum": ["ralph-codex/output/execution"] }
      }
    }
  }
}
