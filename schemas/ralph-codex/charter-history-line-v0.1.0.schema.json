{
  "schema_id": "ralph-codex/charter-history-line",
  "schema_version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "session_id",
    "ts",
    "charter_version",
    "review_state",
    "confirmed",
    "locked",
    "operator_feedback",
    "planning_result",
    "charter"
  ],
  "properties": {
    "schema_id": { "type": "string", "enum": ["ralph-codex/charter-history-line"] },
    "schema_version": { "type": "string", "enum": ["0.1.0"] },
    "session_id": { "type": "string", "pattern": "^\\d{8}T\\d{9}Z_[0-9a-f]{12}$" },
    "ts": { "type": "string", "minLength": 1 },
    "charter_version": { "type": "integer", "minimum": 1 },
    "review_state": { "type": "string", "enum": ["draft", "approved", "superseded"] },
    "confirmed": { "type": "boolean" },
    "locked": { "type": "boolean" },
    "operator_feedback": { "type": "string" },
    "planning_result": { "type": "object" },
    "charter": { "type": "object" }
  }
}
