{
  "schema_id": "ralph-codex/charter",
  "schema_version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "session_id",
    "charter_version",
    "locked",
    "confirmed",
    "updated_at",
    "planning_result",
    "charter"
  ],
  "properties": {
