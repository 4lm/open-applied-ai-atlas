{
  "schema_id": "ralph-codex/run-history-line",
  "schema_version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "session_id",
    "run_id",
    "ts",
    "event",
    "invocation_mode",
    "message_source_kind",
    "message_source_label",
    "summary"
  ],
  "properties": {
    "schema_id": { "type": "string", "enum": ["ralph-codex/run-history-line"] },
    "schema_version": { "type": "string", "enum": ["0.1.0"] },
    "session_id": { "type": "string", "pattern": "^\\d{8}T\\d{9}Z_[0-9a-f]{12}$" },
    "run_id": { "type": "string", "pattern": "^\\d{8}T\\d{9}Z_[0-9a-f]{12}$" },
    "ts": { "type": "string", "minLength": 1 },
    "event": { "type": "string", "enum": ["run_started", "run_completed", "run_failed", "run_aborted"] },
    "invocation_mode": { "type": "string", "enum": ["message", "file", "resume"] },
    "message_source_kind": { "type": "string", "enum": ["inline", "file"] },
    "message_source_label": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" }
  }
}
