{
  "schema_id": "ralph-codex/finished",
  "schema_version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "session_id",
    "status",
    "summary",
    "finished_at",
    "iterations"
  ],
  "properties": {
    "schema_id": { "type": "string", "enum": ["ralph-codex/finished"] },
    "schema_version": { "type": "string", "enum": ["0.1.0"] },
    "session_id": { "type": "string", "pattern": "^\\d{8}T\\d{9}Z_[0-9a-f]{12}$" },
    "status": { "type": "string", "enum": ["completed", "failed", "abandoned"] },
    "summary": { "type": "string", "minLength": 1 },
    "finished_at": { "type": "string", "minLength": 1 },
    "iterations": { "type": "integer", "minimum": 0 }
  }
}
