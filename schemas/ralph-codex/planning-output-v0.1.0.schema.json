{
  "schema_id": "ralph-codex/output/planning",
  "schema_version": "0.1.0",
  "title": "ralph-planning",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "broadening_rationale",
    "research",
    "program_board",
    "active_milestone",
    "current_tranche",
    "next_step",
    "gate_reasoning"
  ],
  "properties": {
    "status": { "type": "string", "enum": ["CHARTER_READY", "BLOCKED"] },
    "summary": { "type": "string", "minLength": 1 },
    "broadening_rationale": { "type": "string", "minLength": 1 },
    "research": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "search_strategy", "findings", "evidence_assessment", "sources", "open_questions"],
      "properties": {
        "status": { "type": "string", "enum": ["completed", "blocked"] },
        "search_strategy": { "type": "string", "minLength": 1 },
        "findings": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence_assessment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["relevance", "quality", "freshness", "refresh_recommended"],
          "properties": {
            "relevance": { "type": "string", "minLength": 1 },
            "quality": { "type": "string", "minLength": 1 },
            "freshness": { "type": "string", "minLength": 1 },
            "refresh_recommended": { "type": "boolean" }
          }
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "url", "source_type", "used_for"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "minLength": 1 },
              "source_type": { "type": "string", "enum": ["primary", "secondary"] },
              "used_for": { "type": "string", "minLength": 1 }
            }
          }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "program_board": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "milestones",
        "success_criteria",
        "validation_categories",
        "explicit_deferrals"
      ],
      "properties": {
        "goal": { "type": "string", "minLength": 1 },
        "milestones": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "title",
              "objective",
              "acceptance_criteria",
              "dependencies",
              "evidence_requirements",
              "status",
              "workstreams"
            ],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "objective": { "type": "string", "minLength": 1 },
              "acceptance_criteria": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "dependencies": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "evidence_requirements": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "status": { "type": "string", "enum": ["planned", "active", "done", "deferred"] },
              "workstreams": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "id",
                    "title",
                    "goal",
                    "required_adjacent_surfaces",
                    "validation",
                    "status"
                  ],
                  "properties": {
                    "id": { "type": "string", "minLength": 1 },
                    "title": { "type": "string", "minLength": 1 },
                    "goal": { "type": "string", "minLength": 1 },
                    "required_adjacent_surfaces": {
                      "type": "array",
                      "minItems": 1,
                      "items": { "type": "string", "minLength": 1 }
                    },
                    "validation": {
                      "type": "array",
                      "minItems": 1,
                      "items": { "type": "string", "minLength": 1 }
                    },
                    "status": { "type": "string", "enum": ["planned", "deferred"] }
                  }
                }
              }
            }
          }
        },
        "success_criteria": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "validation_categories": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "explicit_deferrals": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "active_milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "milestone_id",
        "rationale",
        "success_checkpoint",
        "evidence_focus",
        "target_files",
        "validation"
      ],
      "properties": {
        "milestone_id": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "success_checkpoint": { "type": "string", "minLength": 1 },
        "evidence_focus": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "target_files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "validation": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "current_tranche": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batch_id", "milestone_id", "workstream_ids", "target_files", "intended_outcome", "validation"],
      "properties": {
        "batch_id": { "type": "string", "minLength": 1 },
        "milestone_id": { "type": "string", "minLength": 1 },
        "workstream_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "target_files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "intended_outcome": { "type": "string", "minLength": 1 },
        "validation": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "next_step": { "type": "string", "minLength": 1 },
    "gate_reasoning": { "type": "string", "minLength": 1 }
  }
}
